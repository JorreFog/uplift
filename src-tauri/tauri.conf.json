{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Uplift",
  "version": "0.1.0",
  "identifier": "app.uplift.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Uplift",
        "width": 1280,
        "height": 820,
        "minWidth": 980,
        "minHeight": 640,
        "backgroundColor": "#0E1116"
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' https://cdn.cloudflare.steamstatic.com https://shared.cloudflare.steamstatic.com https://shared.steamstatic.com https://shared.akamai.steamstatic.com data:; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/JorreFog/uplift/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDkwQ0NCMDhFMEQ4MDRFN0IKUldSN1RvQU5qckRNa0dwelBITDNia2UyYVdCb1ZoZmVnSEwrZzlaVGVxamEvV3p2SmFCVlZOa28K"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
